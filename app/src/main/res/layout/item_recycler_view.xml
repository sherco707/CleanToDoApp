<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/itemCons"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/taskId"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginRight="90dp"
            android:paddingLeft="10dp"
            android:text="none"
            android:textColor="@color/black"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/itemCons"
            app:layout_constraintTop_toTopOf="@id/itemCons" />

        <ImageButton
            android:id="@+id/deletetxt"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@color/white"
            android:src="@drawable/baseline_delete_24"
            app:layout_constraintBottom_toBottomOf="@id/itemCons"
            app:layout_constraintRight_toRightOf="@id/itemCons"
            app:layout_constraintTop_toTopOf="@id/itemCons" />

        <ImageButton
            android:id="@+id/editxt"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@color/white"
            android:src="@drawable/edit"
            app:layout_constraintLeft_toRightOf="@id/taskId"
            app:layout_constraintTop_toTopOf="@id/itemCons" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>